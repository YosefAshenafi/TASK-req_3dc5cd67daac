APP_NAME=SmartPark
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (MySQL 8 via docker compose) ───────────────────────────────────
# Host "mysql" resolves inside the compose network; use 127.0.0.1 from the host.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=smartpark
DB_USERNAME=smartpark
DB_PASSWORD=smartpark_dev

# ─── Redis (cache, queue, session) ───────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Field-level encryption key (Docker secret) ──────────────────────────────
FIELD_ENCRYPTION_KEY_PATH=/run/secrets/field_key

# ─── Device Gateway shared secret ────────────────────────────────────────────
# Required on BOTH the backend (to validate X-Gateway-Token) AND the gateway
# container (to attach the header). Must match on both sides or gateway
# ingestion returns 401.
GATEWAY_TOKEN=change-me-local-gateway-token

# ─── Mail (dev: log driver) ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
